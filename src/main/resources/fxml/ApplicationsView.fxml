<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jobhuntos.controller.ApplicationsController">
    <top>
        <VBox spacing="10">
            <Label text="Applications" styleClass="content-header" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search by role or company..." styleClass="search-box" prefWidth="300" />
                <ComboBox fx:id="statusFilter" promptText="All Statuses" styleClass="combo-box" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Add New" styleClass="button-primary" onAction="#handleAdd" />
                <Button text="Edit" onAction="#handleEdit" />
                <Button text="Delete" onAction="#handleDelete" />
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tableView" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colCompany" text="Company" prefWidth="150" />
                <TableColumn fx:id="colRole" text="Role" prefWidth="200" />
                <TableColumn fx:id="colDate" text="Date Applied" prefWidth="120" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
                <TableColumn fx:id="colPriority" text="Priority" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button text="Previous" onAction="#handlePrevPage" />
            <Label fx:id="pageLabel" text="Page 1 of 1" />
            <Button text="Next" onAction="#handleNextPage" />
        </HBox>
    </bottom>
</BorderPane>

