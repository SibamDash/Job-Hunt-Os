<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jobhuntos.controller.DocumentsController">
    <top>
        <VBox spacing="10">
            <Label text="Document Manager" styleClass="content-header" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search documents..." styleClass="search-box" prefWidth="300" />
                <ComboBox fx:id="categoryFilter" promptText="All Categories" styleClass="combo-box" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Upload Document" styleClass="button-primary" onAction="#handleUpload" />
            </HBox>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.4" style="-fx-background-color: transparent;">
            <TableView fx:id="tableView" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colName" text="Document Name" prefWidth="200" />
                    <TableColumn fx:id="colType" text="Category" prefWidth="100" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
            <VBox alignment="CENTER" spacing="15" styleClass="card" style="-fx-background-color: -fx-card-bg;">
                <Label text="Document Preview" styleClass="card-title" />
                <Label fx:id="lblPreviewName" text="Select a document" />
                <StackPane VBox.vgrow="ALWAYS" style="-fx-border-color: -fx-border-color; -fx-background-color: #e0e0e0; -fx-padding: 20;">
                    <Label text="[ DOCUMENT VIEWER ]" style="-fx-font-weight: bold; -fx-text-fill: #666666;" />
                </StackPane>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
