<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<BorderPane styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jobhuntos.controller.ResumesController">
    <top>
        <VBox spacing="10">
            <Label text="Resumes" styleClass="content-header" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Upload Resume" styleClass="button-primary" onAction="#handleUpload" />
                <Button text="Replace Selected" onAction="#handleReplace" />
            </HBox>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.4" style="-fx-background-color: transparent;">
            <TableView fx:id="tableView" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colName" text="Name" prefWidth="200" />
                    <TableColumn fx:id="colType" text="Type" prefWidth="100" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
            <VBox alignment="CENTER" spacing="15" styleClass="card" style="-fx-background-color: -fx-card-bg;">
                <Label text="Resume Preview" styleClass="card-title" />
                <Label fx:id="lblPreviewName" text="Select a resume to preview" />
                <StackPane VBox.vgrow="ALWAYS" style="-fx-border-color: -fx-border-color; -fx-background-color: #e0e0e0; -fx-padding: 20;">
                    <Label text="[ PDF PREVIEW PLACEHOLDER ]" style="-fx-font-weight: bold; -fx-text-fill: #666666;" />
                </StackPane>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
