<?xml version="1.0" encoding="UTF-8"?>
import javafx.scene.control.*
import javafx.scene.layout.*
<BorderPane styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jobhuntos.controller.RecruitersController">
    <top>
        <VBox spacing="10">
            <Label text="Recruiters" styleClass="content-header" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search recruiters..." styleClass="search-box" prefWidth="300" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Add Recruiter" styleClass="button-primary" onAction="#handleAdd" />
            </HBox>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.6" style="-fx-background-color: transparent;">
            <TableView fx:id="tableView" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colName" text="Name" prefWidth="150" />
                    <TableColumn fx:id="colCompany" text="Company" prefWidth="150" />
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
            <VBox spacing="15" styleClass="card" style="-fx-background-color: -fx-card-bg;">
                <Label text="Contact Card" styleClass="card-title" />
                <Label fx:id="lblName" text="Select a recruiter" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <Label fx:id="lblCompany" text="-" style="-fx-text-fill: -fx-text-secondary;" />
                <Separator />
                <Label text="Email:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblEmail" text="-" />
                <Label text="LinkedIn:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblLinkedIn" text="-" />
                <Label text="Follow-up Date:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblFollowUp" text="-" style="-fx-text-fill: -fx-accent;" />
                <Region VBox.vgrow="ALWAYS" />
                <Button text="Send Email" styleClass="button-primary" maxWidth="Infinity" />
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
