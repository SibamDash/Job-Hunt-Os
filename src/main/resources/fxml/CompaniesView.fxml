<?xml version="1.0" encoding="UTF-8"?>
import javafx.scene.control.*
import javafx.scene.layout.*
<BorderPane styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jobhuntos.controller.CompaniesController">
    <top>
        <VBox spacing="10">
            <Label text="Companies" styleClass="content-header" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search companies..." styleClass="search-box" prefWidth="300" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Add Company" styleClass="button-primary" onAction="#handleAdd" />
            </HBox>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.6" style="-fx-background-color: transparent;">
            <TableView fx:id="tableView" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colName" text="Company Name" prefWidth="200" />
                    <TableColumn fx:id="colTech" text="Tech Stack" prefWidth="150" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
            <VBox spacing="15" styleClass="card" style="-fx-background-color: -fx-card-bg;">
                <Label text="Company Details" styleClass="card-title" />
                <Label fx:id="lblDetailName" text="Select a company" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <Label text="Website:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblWebsite" text="-" />
                <Label text="Tech Stack:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblTech" text="-" />
                <Label text="Notes:" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="txtNotes" VBox.vgrow="ALWAYS" editable="false" styleClass="text-area" />
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
